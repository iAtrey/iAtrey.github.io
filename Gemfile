source 'https://rubygems.org'

group :jekyll_plugins do
  gem 'jekyll', '~> 4.3'
  gem 'jekyll-feed'
  gem 'jekyll-sitemap'
  gem 'jekyll-redirect-from'
  gem 'jemoji'
  gem 'webrick', '~> 1.8'
end

# These gems were removed from Ruby's standard library in newer Ruby versions,
# so they must be declared explicitly for Jekyll to run locally.
gem 'csv'
gem 'logger'
gem 'base64'
gem 'bigdecimal'

# NOTE: The 'github-pages' gem (which pins an old Jekyll) was removed so the site
# builds on modern Ruby. This does not affect your live site — GitHub Pages builds
# it on its own servers when you push.
